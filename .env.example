# ClawdBot Railway Client Pack v0.1
# Copy this file into Railway Variables RAW Editor.
# Do NOT commit real tokens, API keys, setup passwords, or pixel IDs to Git.

# -----------------------------
# Core runtime
# -----------------------------
PORT=8080
OPENCLAW_VERSION=2026.4.23
NODE_ENV=production

OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
OPENCLAW_CONFIG_PATH=/data/.openclaw/openclaw.json
OPENCLAW_SKILLS_DIR=/data/.openclaw/skills
OPENCLAW_PLUGINS_DIR=/data/openclaw-plugins

CLAWDBOT_STATE_DIR=/data/.clawdbot
CLAWDBOT_WORKSPACE_DIR=/data/workspace
CLAWDBOT_SKILLS_DIR=/data/.clawdbot/skills
CLAWDBOT_PLUGINS_DIR=/data/clawdbot-plugins
CLAWDBOT_CLIENT_PACK=default

# -----------------------------
# Bootstrap / verification
# -----------------------------
CLAWDBOT_AUTO_CONFIG=auto
CLAWDBOT_BOOTSTRAP_SKILLS=true
CLAWDBOT_BOOTSTRAP_PLUGINS=true
CLAWDBOT_VERIFY_RUNTIME=true
CLAWDBOT_DEFAULT_PROVIDER=deepseek
CLAWDBOT_DEFAULT_MODEL=deepseek/deepseek-chat
CLAWDBOT_VERIFY_LIVE_MODEL=false

# Hot skill sync: thin helper, not a custom marketplace.
CLAWDBOT_SKILLS_SYNC_ENABLED=true
CLAWDBOT_SKILLS_SYNC_INTERVAL_SECONDS=1800
CLAWDBOT_SKILLS_UPDATE_ALL=false
CLAWDBOT_SKILLS_ALLOWLIST_PATH=/data/.clawdbot/skills.allowlist

# -----------------------------
# AI provider keys
# -----------------------------
# Required for default MVP provider.
DEEPSEEK_API_KEY=

# Optional fallback/alternative providers.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LITELLM_API_KEY=
CUSTOM_API_KEY=

# -----------------------------
# Gateway / internal control
# -----------------------------
OPENCLAW_GATEWAY_TOKEN=
CLAWDBOT_GATEWAY_TOKEN=
INTERNAL_GATEWAY_BIND=lan
INTERNAL_GATEWAY_PORT=18789
SELF_HEAL_MAX_ATTEMPTS=3

# -----------------------------
# Optional VK channel
# -----------------------------
# Leave false for clients who do not need VK.
CLAWDBOT_ENABLE_VK=false
VK_COMMUNITY_TOKEN=
VK_GROUP_ID=

# -----------------------------
# Optional UI / setup
# -----------------------------
SETUP_PASSWORD=
ENABLE_WEB_TUI=false
TUI_IDLE_TIMEOUT_MS=300000
TUI_MAX_SESSION_MS=1800000
TELEGRAM_ENABLED=false

# -----------------------------
# Persistent package caches on Railway volume
# -----------------------------
NPM_CONFIG_CACHE=/data/npm-cache
NPM_CONFIG_PREFIX=/data/npm
PNPM_HOME=/data/pnpm
PNPM_STORE_DIR=/data/pnpm-store

# -----------------------------
# Optional marketing / pixels / analytics
# These placeholders are for future client packs.
# They are not required by the current Docker bootstrap.
# -----------------------------
VK_PIXEL_ID=
YANDEX_METRIKA_COUNTER_ID=
META_PIXEL_ID=
GOOGLE_TAG_ID=
