# ClawdBot Railway Client Pack v0.1
# Copy this file into Railway Variables RAW Editor.
# Do NOT commit real tokens, API keys, setup passwords, or pixel IDs to Git.

# -----------------------------
# Runtime
# -----------------------------
OPENCLAW_VERSION=2026.4.23
NODE_ENV=production

# -----------------------------
# AI provider key
# -----------------------------
DEEPSEEK_API_KEY=

# -----------------------------
# Gateway / setup
# -----------------------------
# Railway Template can generate this automatically with ${{secret(64)}}.
# If empty, the container generates and persists a token on /data at first boot.
OPENCLAW_GATEWAY_TOKEN=
SETUP_PASSWORD=

# -----------------------------
# Default model
# -----------------------------
CLAWDBOT_DEFAULT_PROVIDER=deepseek
CLAWDBOT_DEFAULT_MODEL=deepseek/deepseek-chat

# -----------------------------
# Optional VK channel
# -----------------------------
CLAWDBOT_ENABLE_VK=false
VK_COMMUNITY_TOKEN=
VK_GROUP_ID=

# -----------------------------
# Optional flags
# -----------------------------
OPENCLAW_VERIFY_LIVE_MODEL=false
CLAWDBOT_RUN_DOCTOR=true
CLAWDBOT_SYNC_CONFIG_FROM_ENV=true
